        "# ============================================================\n",
        "# 4. CORE SECURITY ENGINE\n",
        "# ============================================================\n",
        "class SentinelSession:\n",
        "    \"\"\"Stateful session: tracks cumulative risk, conversation\n",
        "    history, telemetry logs, and adaptive pattern memory.\"\"\"\n",
        "\n",
        "    def __init__(self):\n",
        "        self.reset()\n",
        "\n",
        "    # ── Public ──────────────────────────────────────────────\n",
        "    def reset(self):\n",
        "        self.logs        = []          # forensic logs\n",
        "        self.conv_hist   = deque(maxlen=10)  # context-aware window\n",
        "        self.cumulative  = 0.0\n",
        "        self.MAX_TOL     = 300.0\n",
        "        self.metrics     = {\n",
        "            \"total\": 0, \"blocked\": 0, \"allowed\": 0,\n",
        "            \"sanitized\": 0, \"egress_blocked\": 0,\n",
        "            \"latencies\": [], \"risk_trend\": []\n",
        "        }\n",
        "\n",
        "    # ── Pre-processing ──────────────────────────────────────\n",
        "    def normalize(self, text: str) -> str:\n",
        "        \"\"\"Strip hidden chars and decode Base64 obfuscation.\"\"\"\n",
        "        text = re.sub(r'[\\u200B-\\u200D\\uFEFF]', '', text)\n",
        "        text = unicodedata.normalize('NFKC', text)\n",
        "        # Leet-speak normalisation (basic)\n",
        "        leet = {'0':'o','1':'i','3':'e','4':'a','5':'s','@':'a','$':'s'}\n",
        "        cleaned = ''.join(leet.get(c, c) for c in text)\n",
        "        try:\n",
        "            decoded = base64.b64decode(text.strip()).decode('utf-8')\n",
        "            if len(decoded) > 4:\n",
        "                return decoded\n",
        "        except Exception:\n",
        "            pass\n",
        "        return cleaned\n",
        "\n",
        "    # ── 3-Tier Scan ─────────────────────────────────────────\n",
        "    def scan(self, text: str):\n",
        "        \"\"\"\n",
        "        Returns (score, level, attack_type, reason, latency)\n",
        "        Tier 0 → Blacklist  (~0 ms)\n",
        "        Tier 1 → Regex patterns  (~0 ms)\n",
        "        Tier 2 → DeBERTa AI  (~100–300 ms)\n",
        "        \"\"\"\n",
        "        t0 = time.time()\n",
        "        lo = text.lower()\n",
        "\n",
        "        # ── Tier 0: Hard blacklist ──────────────────────────\n",
        "        nsfw = [\"sex\", \"porn\", \"pron\", \"nude\", \"x-rated\"]\n",
