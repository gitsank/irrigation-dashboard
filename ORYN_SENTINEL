        "        for phrase in illegal:\n",
        "            if phrase in lo:\n",
        "                return 100.0, \"HIGH\", \"Illegal Request\", f\"Detected phrase: '{phrase}'\", time.time()-t0\n",
        "\n",
        "        # ── Tier 1: Regex jailbreak patterns ───────────────\n",
        "        patterns = [\n",
        "            (r\"ignore\\s+(all\\s+)?previous\\s+instructions?\",\n",
        "             \"Instruction Override\", \"Classic override trigger\"),\n",
        "            (r\"disregard\\s+(all\\s+)?(previous|prior|above)\",\n",
        "             \"Instruction Override\", \"Disregard directive\"),\n",
        "            (r\"you\\s+are\\s+now\\s+(dan|jailbroken|evil|chaos|unrestricted)\",\n",
        "             \"DAN Jailbreak\", \"Persona hijack attempt\"),\n",
        "            (r\"(reveal|show|print|output)\\s+(your\\s+)?(system\\s+prompt|hidden\\s+instructions?|initialization)\",\n",
        "             \"Prompt Extraction\", \"System prompt leak attempt\"),\n",
        "            (r\"(act|pretend|roleplay)\\s+as\\s+(a\\s+)?(hacker|unrestricted|evil|malicious)\",\n",
        "             \"Role Manipulation\", \"Malicious persona injection\"),\n",
        "            (r\"developer\\s+mode|jailbreak\\s+mode|unrestricted\\s+mode\",\n",
        "             \"Mode Injection\", \"Mode override string\"),\n",
        "            (r\"forget\\s+(everything|all\\s+instructions?|previous\\s+context)\",\n",
        "             \"Context Erasure\", \"Memory wipe attempt\"),\n",
        "            (r\"(no\\s+restrictions?|no\\s+limits?|no\\s+rules?|no\\s+filters?)\",\n",
        "             \"Restriction Bypass\", \"Explicit bypass request\"),\n",
        "            (r\"override\\s+(safety|security|restrictions?|filters?|guidelines?)\",\n",
        "             \"Safety Override\", \"Direct safety override\"),\n",
        "        ]\n",
        "        for pat, atype, reason in patterns:\n",
        "            if re.search(pat, lo):\n",
        "                return 99.0, \"HIGH\", atype, reason, time.time()-t0\n",
        "\n",
        "        # Adaptive learned patterns from attack_db\n",
        "        for learned in attack_db.get(\"patterns\", []):\n",
